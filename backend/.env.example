NODE_ENV=development
PORT=8080
FRONTEND_URL=http://localhost:3000
FRONTEND_URL_DEV_ORIGINS=http://localhost:3000
STACKSPONG_MONGODB_URI=mongodb://localhost:27017/stacks-pong

STACKS_NETWORK=testnet
STACKS_API_URL=https://api.testnet.hiro.so
STACKS_CHAIN_ID=2147483648
PONG_CONTRACT_ADDRESS=ST...
PONG_CONTRACT_NAME=pong-escrow

# Local development may load these from .env.enc; production injects them directly.
# Canonical STX account path: m/44'/5757'/0'/0/{account index}
SIGNING_MNEMONIC=
SIGNING_ACCOUNT_INDEX=0
SIGNING_DERIVATION_PATH=m/44'/5757'/0'/0/0
# Optional BIP-39 passphrase. Leave unset for standard Stacks wallets.
SIGNING_MNEMONIC_PASSPHRASE=

# Deprecated compatibility fallback. Prefer SIGNING_MNEMONIC.
SIGNING_PRIVATE_KEY=

# Mainnet:
# STACKS_NETWORK=mainnet
# STACKS_API_URL=https://api.mainnet.hiro.so
# STACKS_CHAIN_ID=1
# PONG_CONTRACT_ADDRESS=SP...
